NEKO_MEMBER_MULTIUSER_USER_PASSWORD=change-me-user-password
NEKO_MEMBER_MULTIUSER_ADMIN_PASSWORD=change-me-admin-password
CLOAKBROWSER_START_URL=https://example.com
# Required for any remote client that is not on the server itself.
# Set this to the server IP that the browser client can actually reach.
NEKO_NAT1TO1=192.168.0.150
# Neko uses the multiuser provider in the compose files. Change the passwords before exposing the HTTP port,
# and still prefer a trusted network, SSH tunnel, firewall allowlist, or reverse proxy authentication.
# Enable Neko built-in file transfer and keep it aligned with the shared downloads directory.
NEKO_FILE_TRANSFER_ENABLED=true
NEKO_FILE_TRANSFER_PATH=/home/neko/Downloads
# Comma-separated unpacked Chromium extension directories to auto-load on browser start.
CLOAKBROWSER_EXTENSION_DIRS=/home/neko/Downloads/pixiv-plugin/unpacked
# Host paths that are bind-mounted into the container so Hermes and Neko share files directly.
CLOAKBROWSER_HOST_PROFILE_DIR=/home/yun/workspace/neko-data/profile
CLOAKBROWSER_HOST_DOWNLOADS_DIR=/home/yun/workspace/neko-data/downloads
# browser-use runs inside the CloakBrowser container and attaches to the local CDP proxy.
BROWSER_USE_SETUP_LOGGING=false
BROWSER_USE_SESSION=default
BROWSER_USE_CDP_URL=http://127.0.0.1:9223
# Optional natural-language browser-use agent wrapper.
# Use host.docker.internal on Linux because the local OpenAI-compatible endpoint is on the host.
OPENAI_BASE_URL=http://host.docker.internal:8317/v1
OPENAI_API_KEY=change...key
OPENAI_MODEL=gpt-5.4-mini
BROWSER_USE_LLM_MODEL=gpt-5.4-mini
BROWSER_USE_LLM_TEMPERATURE=0.2
BROWSER_USE_LLM_TIMEOUT=120
BROWSER_USE_AGENT_MAX_STEPS=5
BROWSER_USE_AGENT_MAX_ACTIONS_PER_STEP=3
BROWSER_USE_AGENT_USE_VISION=false
